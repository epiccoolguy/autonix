{
  "mcpServers": {
    "github": {
      "serverUrl": "https://api.githubcopilot.com/mcp"
    },
    "kubernetes": {
      "command": "pnpx",
      "args": [
        "kubernetes-mcp-server@latest",
        "--read-only",
        "--disable-multi-cluster",
        "--kubeconfig",
        "/Users/miguel/.kube/agent.mlzw.config"
      ]
    },
    "grafana": {
      "command": "uvx",
      "args": ["mcp-grafana", "-t", "stdio", "--disable-write"],
      "env": {
        "GRAFANA_URL": "https://grafana.mlzw.dev",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN_FILE": "/Users/miguel/.config/mcp/grafana-agent-ops-token"
      }
    }
  }
}
