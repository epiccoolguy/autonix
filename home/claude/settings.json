{
  "env": {
    "KUBECONFIG": "/Users/miguel/.kube/agent.mlzw.config"
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git fetch:*)",
      "Bash(git stash list:*)",
      "Bash(git worktree:*)",
      "Bash(git push:*)",
      "Bash(git tag:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go run:*)",
      "Bash(go mod tidy:*)",
      "Bash(gofmt:*)",
      "Bash(goimports:*)",
      "Bash(golangci-lint:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(pnpm:*)",
      "Bash(deno:*)",
      "Bash(tsc:*)",
      "Bash(eslint:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(pyright:*)",
      "Bash(nixfmt:*)",
      "Bash(nixfmt-tree:*)",
      "Bash(nix flake check:*)",
      "Bash(nix build:*)",
      "Bash(nix eval:*)",
      "Bash(make:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(jq:*)",
      "Bash(stat:*)",
      "Bash(file:*)",
      "Bash(which:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(git rev-parse:*)",
      "Bash(git blame:*)",
      "Bash(git describe:*)",
      "Bash(git ls-files:*)",
      "Bash(git config --get:*)",
      "Bash(gh:*)",
      "mcp__github",
      "WebFetch",
      "WebSearch",
      "Bash(kubectl:*)",
      "mcp__kubernetes",
      "mcp__grafana",
      "Bash(argocd:*)",
      "mcp__argocd"
    ],
    "ask": [
      "Bash(kubectl*--kubeconfig*)",
      "Bash(argocd*prd*)",
      "Bash(kubectl*delete*prd*)",
      "Bash(kubectl*prd*delete*)",
      "Bash(kubectl*scale*prd*)",
      "Bash(kubectl*prd*scale*)",
      "Bash(gh repo delete:*)",
      "Bash(gh secret:*)",
      "Bash(gh auth:*)",
      "mcp__github__delete_file",
      "mcp__github__push_files",
      "mcp__github__create_or_update_file",
      "Edit(**/overlays/prd/**)",
      "Write(**/overlays/prd/**)"
    ],
    "defaultMode": "plan"
  },
  "model": "opusplan",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "refreshInterval": 60
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "skipWorkflowUsageWarning": false,
  "theme": "auto",
  "switchModelsOnFlag": false,
  "agentPushNotifEnabled": true,
  "attribution": {
    "commit": "",
    "pr": "",
    "sessionUrl": false
  },
  "fallbackModel": ["opus", "sonnet"],
  "advisorModel": "opus",
  "alwaysThinkingEnabled": true,
  "cleanupPeriodDays": 90,
  "askUserQuestionTimeout": "10m",
  "disableClaudeAiConnectors": true,
  "autoUpdatesChannel": "stable",
  "feedbackSurveyRate": 0,
  "awaySummaryEnabled": true,
  "autoMode": {
    "environment": [
      "$defaults",
      "Organization: personal setup of Miguel Lo-A-Foe (software engineer); primary use: software development and GitOps-based Kubernetes operations",
      "Source control: github.com/epiccoolguy and all repos under it",
      "Trusted internal domains: *.mlzw.dev",
      "Key internal services: Argo CD at argocd.mlzw.dev, Grafana at grafana.mlzw.dev, the mlzw Kubernetes cluster accessed via the scoped kubeconfig ~/.kube/agent.mlzw.config",
      "Sensitive remote targets: prd-suffixed namespaces, apps, and contexts on the mlzw cluster",
      "Protected IaC scopes: overlays/prd in GitOps repos and any promotion of a release to prd"
    ],
    "allow": [
      "$defaults",
      "GitHub collaboration: authoring or updating issues, creating or updating pull requests, and merging pull requests that do not impact production (gh CLI or GitHub MCP tools)",
      "GitOps deploy flow for dev/tst/acc environments: pushing feature branches, opening PRs against master, merging to master, re-pinning overlays/acc image digests, creating vX.Y.Z release tags"
    ],
    "soft_deny": [
      "$defaults",
      "Any action that changes production (prd) desired state or content: editing or re-pinning overlays/prd, promoting a release to prd, or any content-write (create/patch/apply) against prd-suffixed apps/namespaces — these always go to the user for final review. Bounded prd ops (pod delete, scale, argocd sync/action) are RBAC-permitted since #754 but still pause via the ask-rules; prd reads and log reads are fine",
      "Pointing kubectl, the Kubernetes MCP, or argocd at credentials other than the scoped agent kubeconfig (~/.kube/agent.mlzw.config): any --kubeconfig flag or KUBECONFIG override toward admin.mlzw.config or other admin credentials — break-glass admin access always goes to the user"
    ]
  }
}
