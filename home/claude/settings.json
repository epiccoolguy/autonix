{
  "env": {
    "KUBECONFIG": "/Users/miguel/.kube/claude.config"
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git fetch:*)",
      "Bash(git stash list:*)",
      "Bash(git worktree:*)",
      "Bash(git push:*)",
      "Bash(git tag:*)",
      "Bash(ls:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go run:*)",
      "Bash(go mod tidy:*)",
      "Bash(gofmt:*)",
      "Bash(goimports:*)",
      "Bash(golangci-lint:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(pnpm:*)",
      "Bash(deno:*)",
      "Bash(tsc:*)",
      "Bash(eslint:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(pyright:*)",
      "Bash(nixfmt:*)",
      "Bash(nixfmt-tree:*)",
      "Bash(nix flake check:*)",
      "Bash(nix build:*)",
      "Bash(nix eval:*)",
      "Bash(make:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr ready:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue close:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "mcp__github__issue_write",
      "mcp__github__add_issue_comment",
      "mcp__github__sub_issue_write",
      "mcp__github__create_branch",
      "mcp__github__create_pull_request",
      "mcp__github__update_pull_request",
      "mcp__github__update_pull_request_branch",
      "mcp__github__merge_pull_request",
      "Bash(kubectl get:*)",
      "Bash(kubectl describe:*)",
      "Bash(kubectl logs:*)",
      "Bash(kubectl top:*)",
      "Bash(kubectl events:*)",
      "Bash(kubectl explain:*)",
      "Bash(kubectl api-resources:*)",
      "Bash(kubectl api-versions:*)",
      "Bash(kubectl version:*)",
      "Bash(kubectl rollout status:*)",
      "Bash(kubectl rollout history:*)",
      "Bash(kubectl auth can-i:*)",
      "Bash(kubectl config get-contexts:*)",
      "Bash(kubectl config current-context:*)",
      "Bash(argocd app get:*)",
      "Bash(argocd app list:*)",
      "Bash(argocd app diff:*)",
      "Bash(argocd app history:*)",
      "Bash(argocd app resources:*)",
      "Bash(argocd app manifests:*)"
    ],
    "ask": ["Edit(**/overlays/prd/**)", "Write(**/overlays/prd/**)"],
    "defaultMode": "auto"
  },
  "model": "opusplan[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "enableWorkflows": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "refreshInterval": 60
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "effortLevel": "high",
  "skipWorkflowUsageWarning": false,
  "theme": "auto",
  "switchModelsOnFlag": false,
  "agentPushNotifEnabled": true,
  "autoMode": {
    "allow": [
      "$defaults",
      "GitHub collaboration: authoring or updating issues, creating or updating pull requests, and merging pull requests that do not impact production (gh CLI or GitHub MCP tools)",
      "GitOps deploy flow for dev/tst/acc environments: pushing feature branches, opening PRs against master, merging to master, re-pinning overlays/acc image digests, creating vX.Y.Z release tags"
    ],
    "soft_deny": [
      "$defaults",
      "Any action that deploys to or modifies a production (prd) environment: editing or re-pinning overlays/prd, targeting prd-suffixed apps/namespaces/contexts, or promoting a release to prd — production changes always go to the user for final review"
    ]
  }
}
